# Production Environment Variables (Vercel)
# Copy to Vercel project settings; do NOT commit .env.production

# Supabase (Production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_KEY=your-production-service-key

# Redis / Upstash (Production)
REDIS_URL=redis://your-prod-upstash-connection
UPSTASH_REDIS_REST_URL=https://your-prod-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-prod-token

# AI Image Generation
HUGGING_FACE_API_KEY=your-prod-hf-key
POLLINATIONS_API_URL=https://api.pollinations.ai

# External APIs
WIKIPEDIA_API_URL=https://en.wikipedia.org/w/api.php
NOMINATIM_API_URL=https://nominatim.openstreetmap.org

# Observability
SENTRY_AUTH_TOKEN=your-prod-sentry-token
SENTRY_DSN=https://your-prod-dsn@sentry.io/project-id

# Environment
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://officialwho.com
LOG_LEVEL=info
NEXT_PUBLIC_BRAND_NAME=OfficialWho
NEXT_PUBLIC_BRAND_TAGLINE=Verified. Celebrated. Remembered.

# Rate Limiting
FREE_TIER_DAILY_LIMIT=2
PREMIUM_TIER_DAILY_LIMIT=0

# API Budget Alerting
DAILY_API_BUDGET_THRESHOLD=5
ALERT_EMAIL=alerts@legacywho.com

# Image Processing
MAX_IMAGE_SIZE_MB=50
TARGET_DPI=300

# Monetization
MONETIZATION_ENABLED=true
NEXT_PUBLIC_REVENUECAT_API_KEY=appl_your_key
REVENUECAT_API_SECRET=your_secret

# RevenueCat Webhooks
REVENUECAT_WEBHOOK_SECRET=your_webhook_secret
