{
  "version": 2,
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": {
      "description": "Supabase project URL"
    },
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": {
      "description": "Supabase anonymous key"
    },
    "SUPABASE_SERVICE_KEY": {
      "description": "Supabase service role key (server-only)"
    },
    "REDIS_URL": {
      "description": "Redis connection string (Upstash)"
    },
    "UPSTASH_REDIS_REST_URL": {
      "description": "Upstash Redis REST URL"
    },
    "UPSTASH_REDIS_REST_TOKEN": {
      "description": "Upstash Redis REST token"
    },
    "HUGGING_FACE_API_KEY": {
      "description": "Hugging Face API key"
    },
    "SENTRY_AUTH_TOKEN": {
      "description": "Sentry authentication token"
    },
    "SENTRY_DSN": {
      "description": "Sentry DSN for error tracking"
    },
    "NODE_ENV": {
      "description": "Environment (development, staging, production)"
    },
    "NEXT_PUBLIC_APP_URL": {
      "description": "Application URL"
    },
    "LOG_LEVEL": {
      "description": "Logging level (debug, info, warn, error)"
    },
    "FREE_TIER_DAILY_LIMIT": {
      "description": "Free tier daily render limit"
    },
    "DAILY_API_BUDGET_THRESHOLD": {
      "description": "Daily API budget threshold for alerts"
    },
    "MONETIZATION_ENABLED": {
      "description": "Enable/disable monetization features"
    }
  },
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/admin",
      "destination": "/admin/dashboard",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ]
}
